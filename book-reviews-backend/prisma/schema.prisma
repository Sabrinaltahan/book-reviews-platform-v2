generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma" 
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  reviews   Review[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Review {
  id            Int      @id @default(autoincrement())
  bookId        String
  bookTitle     String
  bookCover     String?
  reviewText    String
  rating        Int
  userId        Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId])
}